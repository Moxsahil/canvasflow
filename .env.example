# CanvasFlow — Environment Variables Template
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.

# === App ===
NODE_ENV=development

# === Database ===
# Get this from your Neon dashboard. Format:
#   postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
# For pooled connections in production, use the "-pooler" host variant.
DATABASE_URL=

# === Redis (added in PR #6) ===
REDIS_URL=

# === Auth (added in PR #8) ===
AUTH_SECRET=
JWT_SECRET=
