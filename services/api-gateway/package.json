{
  "name": "@canvasflow/api-gateway",
  "version": "0.0.0",
  "private": true,
  "description": "CanvasFlow API gateway — boards, workspaces, sharing, audit",
  "main": "dist/main.js",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch --exec 'node --env-file=.env'",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo *.tsbuildinfo",
    "lint": "eslint src --max-warnings=0"
  },
  "dependencies": {
    "@canvasflow/db": "workspace:*",
    "@canvasflow/types": "workspace:*",
    "@nestjs/common": "^10.4.13",
    "@nestjs/core": "^10.4.13",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^10.4.13",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.55.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.55.0",
    "@opentelemetry/sdk-node": "^0.55.0",
    "drizzle-orm": "^0.36.4",
    "express": "^4.21.2",
    "jose": "^6.2.3",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@canvasflow/config": "workspace:*",
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.13",
    "@types/express": "^5.0.0",
    "@types/node": "^22.19.19",
    "@types/passport-jwt": "^4.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
