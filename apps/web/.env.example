# CanvasFlow web — Environment Variables Template

NODE_ENV=development

# api-gateway base URL
NEXT_PUBLIC_API_URL=http://localhost:3001

# Auth.js — generated via: openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# Google OAuth 
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Resend
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev

# Database (Consumed by @canvasflow/db) — Neon, format:
#   postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
DATABASE_URL=