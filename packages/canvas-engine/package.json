{
  "name": "@canvasflow/canvas-engine",
  "version": "0.0.0",
  "private": true,
  "description": "Pure canvas rendering engine for CanvasFlow — no React, no DOM coupling",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist .turbo *.tsbuildinfo coverage",
    "lint": "eslint src --max-warnings=0"
  },
  "dependencies": {
    "@canvasflow/types": "workspace:*",
    "roughjs": "^4.6.6"
  },
  "devDependencies": {
    "@canvasflow/config": "workspace:*",
    "@vitest/coverage-v8": "^2.1.8",
    "canvas": "^2.11.2",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
