{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "CanvasFlow NestJS",
  "extends": "./base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "ignoreDeprecations": "5.0",
    "outDir": "dist",
    "rootDir": "src",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "target": "ES2022",
    "isolatedModules": false
  },
  "include": ["src/**/*"]
}
